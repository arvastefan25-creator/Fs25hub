backend:
  name: git-gateway
  branch: main

media_folder: "images/uploads"
public_folder: "/images/uploads"

collections:
    - name: "mods"
    label: "Moduri FS25"
    folder: "_mods"
    create: true
    slug: "{{slug}}"
    fields:
            - {label: "Nume Mod", name: "title", widget: "string"}
            - {label: "Poza Mod", name: "image", widget: "image"}
            - {label: "Autor", name: "author", widget: "string"}
            - {label: "Categorie", name: "category", widget: "string"}
            - {label: "Marime", name: "size", widget: "string"}
            - {label: "Versiune", name: "version", widget: "string"}
            - {label: "Link Download", name: "download", widget: "string"}
